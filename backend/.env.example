PORT=5000
# DB_DIALECT defaults to 'sqlite' (no installation needed — data stored in campushive.sqlite)
# Set DB_DIALECT=mysql and fill in the fields below to use MySQL instead
DB_DIALECT=sqlite
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=campushive
JWT_SECRET=supersecretjwtkey_replace_me_in_production
